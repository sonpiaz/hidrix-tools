# Brave Search API — Free: 2000 queries/month
# Get yours at: https://api.search.brave.com
BRAVE_API_KEY=

# GetXAPI — For X/Twitter search, threads, user posts ($0.001/call)
# Get yours at: https://getxapi.com
GETXAPI_KEY=

# RapidAPI — For Reddit, YouTube, TikTok search (X fallback)
# Get yours at: https://rapidapi.com
RAPIDAPI_KEY=

# SimilarWeb (separate RapidAPI key)
SIMILAR_WEB_RAPIDAPI_KEY=

# Apify — For Facebook group/page/search scraping
# Get yours at: https://console.apify.com/settings/integrations
# Free tier: $5/month credit
APIFY_API_TOKEN=

# Tavily — For web search and content extraction
# Get yours at: https://app.tavily.com (1000 free credits/month)
TAVILY_API_KEY=

# Fetch provider for web_fetch tool
# Options: 'readability' (default) | 'tavily' | 'apify'
FETCH_PROVIDER=

# Meta Ad Library API — FREE, official
# Get yours at: https://www.facebook.com/ads/library/api/
# Requires: FB Developer account (free)
META_ADS_ACCESS_TOKEN=
