# Web search (Brave Search - free: 2000 queries/mo)
BRAVE_API_KEY=

# RapidAPI (shared key for social media search)
RAPIDAPI_KEY=

# X/Twitter search (RapidAPI endpoints - required, no defaults)
X_SEARCH_URL=
X_API_HOST=

# Reddit search (RapidAPI endpoints - required, no defaults)
REDDIT_SEARCH_URL=
REDDIT_API_HOST=

# SimilarWeb (separate RapidAPI key)
SIMILAR_WEB_URL=
SIMILAR_WEB_API_HOST=
SIMILAR_WEB_RAPIDAPI_KEY=

# YouTube (optional - has defaults)
# YOUTUBE_SEARCH_URL=https://youtube-api49.p.rapidapi.com
# YOUTUBE_API_HOST=youtube-api49.p.rapidapi.com

# TikTok (optional - has defaults)
# TIKTOK_SEARCH_URL=https://tiktok-api23.p.rapidapi.com
# TIKTOK_API_HOST=tiktok-api23.p.rapidapi.com
